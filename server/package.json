{
  "name": "task-app-server",
  "version": "1.0.0",
  "description": "Simple task app backend for DevOps demo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:docker": "wsl bash ./scripts/dev.sh",
    "prod:docker": "wsl bash ./scripts/prod.sh",
    "test": "jest --detectOpenHandles --forceExit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "devops"
  ],
  "author": "Will",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.5.0"
  },
  "devDependencies": {
    "eslint": "^9.34.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
